{
	"name": "@bindu/communication",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"description": "Bindu Communications — observable, verifiable A2A traffic for operators, auditors, and developers.",
	"license": "Apache-2.0",
	"scripts": {
		"dev": "concurrently -n web,api -c blue,yellow \"npm:dev:web\" \"npm:dev:api\"",
		"dev:web": "vite",
		"dev:api": "tsx watch server/index.ts",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"typecheck": "tsc -b --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.0",
		"@phosphor-icons/react": "^2.1.10",
		"better-sqlite3": "^11.3.0",
		"clsx": "^2.1.1",
		"hono": "^4.7.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router": "^7.5.3",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"@types/better-sqlite3": "^7.6.11",
		"@types/node": "^22.1.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.0.0",
		"tailwindcss": "^4.0.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0"
	}
}
